# Every VITE_* variable below can be supplied two ways:
#   - BUILD TIME  (.env / .env.production): inlined by Vite. Used for `yarn dev`
#                 and the static GitHub Pages build.
#   - RUNTIME     (Docker): passed as container env vars (-e VITE_FOO=bar). The
#                 entrypoint writes them into config.js at startup, so one built
#                 image serves any environment. See docker-entrypoint.sh.
# Runtime values win; otherwise the build-time value is used as fallback.

# API Configuration
# Backend API base URL - update for production deployment
VITE_API_BASE_URL=http://localhost:3003

# Blockchain Configuration
# Ethereum mainnet chain ID (1 for mainnet, 5 for Goerli, 11155111 for Sepolia)
VITE_CHAIN_ID=1

# WalletConnect Configuration
# Get your project ID from https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Application Configuration
VITE_APP_NAME=CSM ICS Admin Panel
VITE_APP_VERSION=0.1.0

# Authentication Configuration
# Domain for SIWE messages - update for production
VITE_SIWE_DOMAIN=localhost:5173
VITE_SIWE_STATEMENT=Sign in to CSM ICS Admin Panel

# Development Configuration
# Enable debug mode for development
VITE_DEBUG_MODE=true
